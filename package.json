{
  "name": "life",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "./scripts/run-with-local-jdk17.sh npx cap open android",
    "android:run": "npm run android:sync && ./scripts/run-with-local-jdk17.sh npx cap run android",
    "android:apk:debug": "npm run android:sync && ./scripts/android-gradlew.sh assembleDebug",
    "android:apk:release": "npm run android:sync && ./scripts/android-gradlew.sh assembleRelease",
    "android:bundle:release": "npm run android:sync && ./scripts/android-gradlew.sh bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^7.6.2",
    "@capacitor/core": "^8.3.1",
    "@capacitor/local-notifications": "^8.0.2",
    "@supabase/supabase-js": "^2.105.1",
    "dayjs": "^1.11.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
